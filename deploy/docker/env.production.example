# Copy to a file outside the repository, chmod 600, then source it before
# running validate-production-env.sh and Docker Compose. Never commit values.
# Example: defensive-ai-gateway@sha256:<approved 64-hex digest>
DEFENSIVE_AI_IMAGE=
DEFENSIVE_AI_API_TOKEN=
DEFENSIVE_AI_INGEST_TOKEN=
DEFENSIVE_AI_OPERATOR_TOKEN=
DEFENSIVE_AI_APPROVER_TOKEN=

# local | ollama | gateway
DEFENSIVE_AI_LLM_PROVIDER=local
DEFENSIVE_AI_LLM_ENDPOINT=
DEFENSIVE_AI_LLM_MODEL=local-rule-analyst
DEFENSIVE_AI_LLM_ALLOWED_HOSTS=127.0.0.1,localhost,::1
DEFENSIVE_AI_LLM_API_KEY=

DEFENSIVE_AI_DATA_RETENTION_DAYS=90
DEFENSIVE_AI_AUDIT_RETENTION_DAYS=365
DEFENSIVE_AI_MEMORY_EVENT_RETENTION_DAYS=365
