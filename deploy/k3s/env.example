# Required in production. Use a strong random value.
DEFENSIVE_AI_API_TOKEN=replace-with-a-strong-token

# Required only when using llm.provider: gateway.
DEFENSIVE_AI_LLM_API_KEY=replace-if-using-an-enterprise-llm-gateway

# Optional helper variables used by install-k3s-bundle.sh.
K3S_NAMESPACE=defensive-ai-gateway
K3S_IMAGE_DIR=images
