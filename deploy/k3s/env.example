# Copy this file to .env, run `chmod 600 .env`, then fill the required values.
# Every role token must be distinct, non-placeholder, and at least 32 characters.
# Use `install.sh --demo-mode` only for an isolated, temporary demonstration.
DEFENSIVE_AI_API_TOKEN=

# Required with `--with-syslog`. Vector receives only this ingest token and never
# receives the administrator token. Keep every role token distinct in production.
DEFENSIVE_AI_INGEST_TOKEN=

# Required in production. The admin token remains break-glass only; normal users
# receive the operator and approver principals.
DEFENSIVE_AI_OPERATOR_TOKEN=
DEFENSIVE_AI_APPROVER_TOKEN=

# Required production TLS ingress and source allowlist. The TLS Secret must
# already exist in namespace defensive-ai-gateway. Never use 0.0.0.0/0 or ::/0.
DEFENSIVE_AI_PUBLIC_HOST=gateway.internal.example
DEFENSIVE_AI_TLS_SECRET=defensive-ai-gateway-tls
DEFENSIVE_AI_ALLOWED_SOURCE_CIDRS=10.0.0.0/8,192.168.0.0/16

# Required with --with-syslog. These are device/collector networks, not users.
DEFENSIVE_AI_SYSLOG_SOURCE_CIDRS=10.20.0.0/16

# local | ollama | gateway. Ollama may use an explicitly allowlisted internal
# http endpoint; gateway must use https and also requires the API key.
DEFENSIVE_AI_LLM_PROVIDER=local
DEFENSIVE_AI_LLM_ENDPOINT=
DEFENSIVE_AI_LLM_MODEL=local-rule-analyst
DEFENSIVE_AI_LLM_ALLOWED_HOSTS=127.0.0.1,localhost,::1
DEFENSIVE_AI_LLM_API_KEY=

DEFENSIVE_AI_DATA_RETENTION_DAYS=90
DEFENSIVE_AI_AUDIT_RETENTION_DAYS=365
DEFENSIVE_AI_MEMORY_EVENT_RETENTION_DAYS=365

# Number of pre-upgrade SQLite rollback points retained on the same PVC.
DEFENSIVE_AI_BACKUP_RETENTION_COUNT=5

# Optional helper variables used by install-k3s-bundle.sh.
K3S_IMAGE_DIR=images
